# GCM MCP Server — Environment Variables
# ========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to version control

# =============================================================================
# Required — GCM Server Connection
# =============================================================================

# GCM server IP or hostname
GCM_HOST=

# Your GCM login credentials
GCM_USERNAME=
GCM_PASSWORD=

# OIDC client secret from Kubernetes:
#   kubectl get secret oidc-client-secret -n gcmapp \
#     -o jsonpath='{.data.CLIENT_SECRET}' | base64 -d
GCM_CLIENT_SECRET=

# =============================================================================
# Optional — Defaults shown
# =============================================================================

# GCM API gateway port
# GCM_API_PORT=31443

# Keycloak identity provider port
# GCM_KEYCLOAK_PORT=30443

# OIDC client ID (usually 'gcmclient')
# GCM_CLIENT_ID=gcmclient

# Authentication mode
# GCM_AUTH_MODE=oauth2

# SSL certificate verification (set to 'true' for production with valid certs)
# GCM_VERIFY_SSL=false

# API request timeout in seconds
# GCM_REQUEST_TIMEOUT=30
